# Copy this file to .env before deploying with docker compose.
# Replace every secret/example value before using it on a public server.

# Public service
HTTP_PORT=80
VITE_API_PREFIX=/api

# PostgreSQL
POSTGRES_DB=paper_mind
POSTGRES_USER=paper_mind
POSTGRES_PASSWORD=change-me-postgres-password

# Redis
REDIS_PASSWORD=change-me-redis-password
REDIS_DATABASE=0

# RabbitMQ
RABBITMQ_USERNAME=paper_mind
RABBITMQ_PASSWORD=change-me-rabbitmq-password

# DashScope / AI
DASHSCOPE_API_KEY=sk-your-dashscope-api-key
PGVECTOR_DIMENSIONS=1536
PGVECTOR_INDEX_TYPE=hnsw
PGVECTOR_DISTANCE_TYPE=cosine_distance
PGVECTOR_BATCH_SIZE=10000
PGVECTOR_TABLE_NAME=vector_store

# Logging
LOG_LEVEL_APP=INFO
LOG_LEVEL_DOCUMENT=INFO
LOG_LEVEL_RAG=INFO
LOG_LEVEL_AGENT=INFO
LOG_LEVEL_LITERATURE=INFO
LOG_LEVEL_VECTOR=INFO
LOG_LEVEL_AI=INFO

# Mail verification via Resend
RESEND_ENABLED=true
RESEND_API_KEY=
RESEND_FROM="PaperMind <noreply@example.com>"
RESEND_ENDPOINT=https://api.resend.com/emails
RESEND_TIMEOUT=10s

# JWT and initial admin
JWT_ISSUER=paper-mind
JWT_SECRET=change-me-to-a-random-string-at-least-32-characters
JWT_ACCESS_TOKEN_TTL=2h
BOOTSTRAP_ADMIN_ENABLED=false
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_DISPLAY_NAME="System Administrator"

# Document ingestion
DOCUMENT_INGESTION_KEEP_UPLOAD_FILE=false
DOCUMENT_INGESTION_MAX_RETRY_COUNT=3
DOCUMENT_INGESTION_CLEANUP_ENABLED=true
DOCUMENT_INGESTION_CLEANUP_RETENTION=24h
DOCUMENT_INGESTION_CLEANUP_CRON="0 0 * * * *"
DOCUMENT_INGESTION_LISTENER_CONCURRENCY=2
DOCUMENT_INGESTION_LISTENER_MAX_CONCURRENCY=4

# Literature search
LITERATURE_OPENALEX_ENABLED=true
LITERATURE_OPENALEX_ENDPOINT=https://api.openalex.org/works
LITERATURE_OPENALEX_TIMEOUT=10s
LITERATURE_OPENALEX_MAILTO=
LITERATURE_SEARCH_CACHE_ENABLED=true
LITERATURE_SEARCH_CACHE_TTL=20m
LITERATURE_SEARCH_CACHE_LOCK_TTL=10s
LITERATURE_SEARCH_CACHE_WAIT_RETRY_INTERVAL=100ms
LITERATURE_SEARCH_CACHE_WAIT_MAX_ATTEMPTS=5
LITERATURE_SEARCH_CACHE_TTL_JITTER=2m

# Aliyun OSS. Leave empty to disable OSS-backed avatar storage.
ALIYUN_OSS_ENDPOINT=
ALIYUN_OSS_BUCKET=
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
ALIYUN_OSS_PUBLIC_BASE_URL=
ALIYUN_OSS_AVATAR_PREFIX=avatars
ALIYUN_OSS_AVATAR_MAX_SIZE=5MB

# RAG
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120
RAG_DEFAULT_TOP_K=3
RAG_SIMILARITY_THRESHOLD=0
RAG_RERANK_ENABLED=true
RAG_RERANK_MODEL=qwen3-rerank
RAG_RERANK_CANDIDATE_MULTIPLIER=3
RAG_RERANK_TIMEOUT=10s
RAG_RERANK_BASE_URL=https://dashscope.aliyuncs.com

# Security throttling
REGISTER_EMAIL_CODE_TTL=5m
REGISTER_EMAIL_CODE_EMAIL_COOLDOWN=60s
REGISTER_EMAIL_CODE_EMAIL_DAILY_LIMIT=10
REGISTER_EMAIL_CODE_IP_MINUTE_LIMIT=20
REGISTER_EMAIL_CODE_IP_DAILY_LIMIT=200
LOGIN_ATTEMPT_ENABLED=true
LOGIN_ATTEMPT_MAX_FAILURES=5
LOGIN_ATTEMPT_WINDOW=10m
LOGIN_ATTEMPT_LOCK_DURATION=10m
